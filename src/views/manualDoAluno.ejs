<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Manual do Usuário</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/sidebar.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
    <link rel="stylesheet" href="/CSS/aluno.css">
    <style>
        .pdf-container {
            width: 100%;
            height: calc(100vh - 150px);
            margin-top: 20px;
            border: 2px solid #1a1a1a;
            border-radius: 12px;
            background: #080808;
        }
        
        .pdf-container iframe {
            width: 100%;
            height: 100%;
            border: none;
            border-radius: 12px;
        }
        
        .pdf-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        
        .pdf-title {
            font-size: 1.2rem;
            color: #217346;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        
        .btn-download {
            padding: 10px 20px;
            background: transparent;
            border: 2px solid #217346;
            color: #217346;
            border-radius: 8px;
            text-decoration: none;
            transition: 0.3s;
        }
        
        .btn-download:hover {
            background: #217346;
            color: white;
        }
    </style>
</head>
<body class="dash-body">
    <%- include('partials/barAluno) %>
    
    <div class="main-layout">
        <header class="dash-header">
            <div class="logo">
                <img src="/IMG/logo3-green.png" alt="AnalisAI">
            </div>
            <h2 class="page-title">MANUAL DO USUÁRIO</h2>
        </header>
        
        <div class="pdf-header">
            <span class="pdf-title">DOCUMENTO ORIENTADOR</span>
            <a href="/PDF/manualDoAluno.pdf" download class="b">
                <i class="fas fa-download"></i> BAIXAR PDF
            </a>
        </div>
        
        <div class="pdf-container">
            <iframe src="/PDF/manualDoAluno.pdf"></iframe>
        </div>
    </div>
</body>
</html>