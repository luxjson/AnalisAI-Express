<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<style>
    .sidebar .side-link i {
        transition: all 0.3s ease;
    }
    
    .sidebar .side-link:hover i {
        transform: scale(1.1);
    }
    
    .sidebar .side-link.active {
        background-color: rgba(33, 115, 70, 0.1);
        color: #217346;
        border-color: rgba(33, 115, 70, 0.3);
    }
    
    .sidebar-bottom .side-link:last-child:hover {
        background-color: #21734627;
        border-color: #21734650;
        color: #217346;
    }

    #infoModal.modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.95);
        backdrop-filter: blur(10px);
        z-index: 2000;
        justify-content: center;
        align-items: center;
    }

    #infoModal .modal-content {
        background-color: #080808;
        border: 2px solid #217346;
        border-radius: 30px;
        padding: 50px 40px;
        max-width: 450px;
        width: 90%;
        position: relative;
        text-align: center;
        animation: fadeInModal 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes fadeInModal {
        from { opacity: 0; transform: scale(0.95) translateY(-10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }

    #infoModal .close-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        background: none;
        border: none;
        color: #444;
        font-size: 28px;
        cursor: pointer;
        transition: transform 0.3s ease, color 0.3s ease;
    }

    #infoModal .close-btn:hover {
        color: #217346;
        transform: rotate(90deg);
    }

    #infoModal .modal-logo {
        width: 220px;
        margin-bottom: 15px;
    }

    #infoModal .version-text {
        font-size: 1rem;
        color: #217346;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    #infoModal .copyright-text {
        font-size: 0.8rem;
        color: #666;
        letter-spacing: 1px;
        text-transform: uppercase;
        line-height: 1.6;
        margin: 5px 0;
    }

    #infoModal .modal-body p:last-child {
        margin-top: 15px;
        color: #217346;
        font-weight: normal;
    }
</style>

<aside class="sidebar">
    <div class="sidebar-top">
        <a href="/aluno/dashboard" title="Dashboard" class="side-link">
            <i class="fas fa-home"></i>
        </a>
        <a href="/aluno/competencias" title="Minhas Competências" class="side-link">
            <i class="fa-solid fa-medal"></i>
        </a>
        <a href="/aluno/tarefas" title="Minhas tarefas" class="side-link">
            <i class="fa-solid fa-tasks"></i>
        </a>
        <a href="/aluno/evolucao" title="Minha Evolução" class="side-link">
            <i class="fas fa-chart-line"></i>
        </a>
    </div>
    
    <div class="sidebar-bottom">
        <a href="/aluno/config" title="Configurações" class="side-link"><i class="fas fa-cog"></i></a>
        <a href="/aluno/equipe" title="Equipe de desenvolvedores" class="side-link">
            <i class="fas fa-code"></i>
        </a>
        <a href="javascript:void(0)" title="Sobre o site" class="side-link" onclick="openModal()">
            <i class="fas fa-info-circle"></i>
        </a>
    </div>
</aside>

<div id="infoModal" class="modal-overlay">
    <div class="modal-content">
        <button class="close-btn" onclick="closeModal()">
            <i class="fas fa-times-circle"></i>
        </button>
        <div class="modal-body">
            <img src="/IMG/logo3-green.png" alt="AnalisAI" class="modal-logo">
            <h3 class="version-text">VERSÃO 1.0</h3>
            <p class="copyright-text">© SENAI - Serviço Nacional de Aprendizagem Industrial</p>
            <p class="copyright-text" style="margin-top: 10px; color: #217346;">ÁREA DO ALUNO</p>
        </div>
    </div>
</div>

<style>
    .sidebar .side-link i {
        transition: all 0.3s ease;
    }
    
    .sidebar .side-link:hover i {
        transform: scale(1.1);
    }
    
    .sidebar .side-link.active {
        background-color: rgba(33, 115, 70, 0.1);
        color: #217346;
        border-color: rgba(33, 115, 70, 0.3);
    }
    
    
    .modal-content .version-text {
        color: #217346;
    }
    
    
    .sidebar-bottom .side-link:last-child:hover {
        background-color: #21734627;
        border-color: #21734650;
        color: #217346;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const currentPath = window.location.pathname;
        const links = document.querySelectorAll('.side-link');
        
        links.forEach(link => {
            const linkPath = link.getAttribute('href');
            if (linkPath && !linkPath.includes('logout') && currentPath === linkPath) {
                link.classList.add('active');
            } else {
                link.classList.remove('active');
            }
        });
    });

    function openModal() {
        const modal = document.getElementById('infoModal');
        modal.style.display = 'flex';
    }

    function closeModal() {
        const modal = document.getElementById('infoModal');
        modal.style.display = 'none';
    }

    window.onclick = function(event) {
        const modal = document.getElementById('infoModal');
        if (event.target == modal) {
            closeModal();
        }
    }
</script>