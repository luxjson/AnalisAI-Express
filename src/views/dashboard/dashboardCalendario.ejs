<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Calendário Escolar</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/calendario.css">
    <link rel="stylesheet" href="/CSS/edit.css">
    <link rel="stylesheet" href="/CSS/sidebar.css">
    <link rel="stylesheet" href="/CSS/dashboard.css">
</head>
<body class="dash-body">
    <%- include('../partials/barProfessor') %>
    
    <div class="main-layout">
        <header class="dash-header">
            <div class="logo">
                <img src="/IMG/logo3-white.png" alt="AnalisAI">
            </div>
            <h2 class="page-title">CALENDÁRIO ESCOLAR</h2>
        </header>
        
        <% if (success_msg && success_msg.length > 0) { %>
            <div class="alert alert-success">
                <%= success_msg %>
                <span class="close-alert" onclick="this.parentElement.style.display='none'">&times;</span>
            </div>
        <% } %>
        
        <% if (error_msg && error_msg.length > 0) { %>
            <div class="alert alert-error">
                <%= error_msg %>
                <span class="close-alert" onclick="this.parentElement.style.display='none'">&times;</span>
            </div>
        <% } %>

        
        
        <div class="calendario-container">
            <div class="calendario-main">
                <div class="calendario-header">
                    <div class="calendario-mes">
                        <button class="btn-mes" onclick="mudarMes(-1)">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <h2 id="mesAtual">
                            <%= new Date(filtros.ano, filtros.mes-1).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' }) %>
                        </h2>
                        <button class="btn-mes" onclick="mudarMes(1)">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                    
                    <form method="GET" action="/dashboard/calendario" id="filtroForm">
                        <input type="hidden" name="mes" id="mesInput" value="<%= filtros.mes %>">
                        <input type="hidden" name="ano" id="anoInput" value="<%= filtros.ano %>">
                        <input type="hidden" name="turma" value="<%= filtros.turma %>">
                    </form>
                </div>
                
                <div class="calendario-grid" id="calendarioGrid">
                    <div class="dia-semana">DOM</div>
                    <div class="dia-semana">SEG</div>
                    <div class="dia-semana">TER</div>
                    <div class="dia-semana">QUA</div>
                    <div class="dia-semana">QUI</div>
                    <div class="dia-semana">SEX</div>
                    <div class="dia-semana">SÁB</div>
                    
                    <% 
                        const primeiroDia = new Date(filtros.ano, filtros.mes-1, 1);
                        const ultimoDia = new Date(filtros.ano, filtros.mes, 0);
                        const diasNoMes = ultimoDia.getDate();
                        const inicioSemana = primeiroDia.getDay();
                        
                        for (let i = 0; i < inicioSemana; i++) { 
                    %>
                        <div class="dia-cell outro-mes"></div>
                    <% } %>
                    
                    <% for (let dia = 1; dia <= diasNoMes; dia++) { 
                        const dataStr = `${filtros.ano}-${String(filtros.mes).padStart(2,'0')}-${String(dia).padStart(2,'0')}`;
                        const eventosDia = eventos.filter(e => {
                            const inicio = new Date(e.data_inicio);
                            const fim = e.data_fim ? new Date(e.data_fim) : inicio;
                            const dataAtual = new Date(dataStr);
                            return dataAtual >= inicio && dataAtual <= fim;
                        });
                        const feriadosDia = feriados.filter(f => {
                            const dataFeriado = new Date(f.data);
                            return dataFeriado.getDate() === dia && 
                                   dataFeriado.getMonth() + 1 === filtros.mes;
                        });
                    %>
                        <div class="dia-cell" data-data="<%= dataStr %>">
                            <div class="dia-numero"><%= dia %></div>
                            <div class="dia-eventos">
                                <% feriadosDia.forEach(f => { %>
                                    <div class="evento-item evento-feriado" title="<%= f.nome %>">
                                        <i class="fas fa-star"></i> <%= f.nome %>
                                    </div>
                                <% }); %>
                                <% eventosDia.forEach(e => { %>
                                    <div class="evento-item" style="background: <%= e.cor %>" 
                                         title="<%= e.titulo %>">
                                        <%= e.titulo %>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <div class="calendario-sidebar">
                <h3 style="color: #fff; margin-bottom: 20px;">FILTROS</h3>
                
                <div class="filtros-calendario">
                    <div class="filtro-group">
                        <label>TURMA</label>
                        <select class="filtro-select" onchange="filtrarTurma(this.value)">
                            <option value="">TODAS AS TURMAS</option>
                            <option value="1º MÉDIO" <%= filtros.turma === '1º MÉDIO' ? 'selected' : '' %>>1º MÉDIO</option>
                            <option value="2º MÉDIO" <%= filtros.turma === '2º MÉDIO' ? 'selected' : '' %>>2º MÉDIO</option>
                            <option value="3º MÉDIO" <%= filtros.turma === '3º MÉDIO' ? 'selected' : '' %>>3º MÉDIO</option>
                            <option value="9º FUNDAMENTAL" <%= filtros.turma === '9º FUNDAMENTAL' ? 'selected' : '' %>>9º FUNDAMENTAL</option>
                        </select>
                    </div>
                </div>
                
                <h3 style="color: #fff; margin: 20px 0;">LEGENDA</h3>
                
                <div class="legenda-item">
                    <div class="legenda-cor" style="background: #ff0101;"></div>
                    <span class="legenda-texto">Feriados</span>
                </div>
                
                <% tipos.forEach(t => { %>
                    <div class="legenda-item">
                        <div class="legenda-cor" style="background: <%= t.cor %>;"></div>
                        <span class="legenda-texto"><%= t.tipo %></span>
                        <span class="legenda-count"><%= t.total %></span>
                    </div>
                <% }); %>
                
                <button class="btn-novo-evento" onclick="abrirModalEvento()">
                    <i class="fas fa-plus"></i> NOVO EVENTO
                </button>
                
                <button class="btn-novo-evento" style="background: #800080;" onclick="abrirModalFeriado()">
                    <i class="fas fa-star"></i> NOVO FERIADO
                </button>
                
                <h3 style="color: #fff; margin: 20px 0;">PRÓXIMOS EVENTOS</h3>

                <div class="eventos-lista">
                    <% 
                        const todosEventos = [
                            ...eventos.map(e => ({...e, tipo: 'evento'})),
                            ...feriados.map(f => ({
                                id: `feriado-${f.id}`,
                                titulo: f.nome,
                                data_inicio: f.data,
                                data_fim: f.data,
                                cor: '#ff0101',
                                tipo: 'feriado',
                                feriado_id: f.id
                            }))
                        ].sort((a, b) => new Date(a.data_inicio) - new Date(b.data_inicio)).slice(0, 10);
                    %>
                    
                    <% todosEventos.forEach(e => { %>
                        <div class="evento-lista-item">
                            <div class="evento-lista-cor" style="background: <%= e.cor %>"></div>
                            <div class="evento-lista-info">
                                <div class="evento-lista-titulo">
                                    <%= e.titulo %>
                                    <% if (e.tipo === 'feriado') { %>
                                        <span style="color: #ff0101; font-size: 0.7rem;">(FERIADO)</span>
                                    <% } %>
                                </div>
                                <div class="evento-lista-data">
                                    <%= new Date(e.data_inicio).toLocaleDateString('pt-BR') %>
                                </div>
                            </div>
                            <% if (userCargo === 'Admin') { %>
                                <button class="evento-lista-remover" onclick="removerItem('<%= e.tipo %>', <%= e.feriado_id || e.id %>)">
                                    <i class="fas fa-times"></i>
                                </button>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
    
    <div id="eventoModal" class="modal-overlay">
        <div class="modal-content modal-lg">
            <button class="close-btn" onclick="fecharModal('eventoModal')">
                <i class="fas fa-times-circle"></i>
            </button>
            
            <h2 class="section-title-2">NOVO EVENTO</h2>
            
            <form action="/dashboard/calendario/evento" method="POST" class="filter-options">
                <label>TÍTULO</label>
                <input type="text" name="titulo" class="filter-input" required>
                
                <label style="margin-top:15px">DESCRIÇÃO</label>
                <textarea name="descricao" class="filter-input" rows="3"></textarea>
                
                <div style="display:flex; gap:15px; margin-top:15px">
                    <div style="flex:1">
                        <label>TIPO</label>
                        <select name="tipo" class="filter-input" required>
                            <option value="evento">Evento</option>
                            <option value="prova">Prova</option>
                            <option value="tarefa">Tarefa</option>
                            <option value="reuniao">Reunião</option>
                            <option value="feriado">Feriado</option>
                        </select>
                    </div>
                    <div style="flex:1">
                        <label>COR</label>
                        <input type="color" name="cor" class="filter-input" value="#ff0101">
                    </div>
                </div>
                
                <div style="display:flex; gap:15px; margin-top:15px">
                    <div style="flex:1">
                        <label>DATA INÍCIO</label>
                        <input type="date" name="data_inicio" class="filter-input" required>
                    </div>
                    <div style="flex:1">
                        <label>DATA FIM</label>
                        <input type="date" name="data_fim" class="filter-input">
                    </div>
                </div>
                
                <div style="margin-top:15px">
                    <label>TURMA (opcional)</label>
                    <select name="turma" class="filter-input">
                        <option value="">TODAS AS TURMAS</option>
                        <option value="1º MÉDIO">1º MÉDIO</option>
                        <option value="2º MÉDIO">2º MÉDIO</option>
                        <option value="3º MÉDIO">3º MÉDIO</option>
                        <option value="9º FUNDAMENTAL">9º FUNDAMENTAL</option>
                    </select>
                </div>
                
                <button type="submit" class="btn-action" style="margin-top:25px; width:100%">
                    <i class="fas fa-save"></i> SALVAR EVENTO
                </button>
            </form>
        </div>
    </div>
    
    <div id="feriadoModal" class="modal-overlay">
        <div class="modal-content modal-lg">
            <button class="close-btn" onclick="fecharModal('feriadoModal')">
                <i class="fas fa-times-circle"></i>
            </button>
            
            <h2 class="section-title-2">NOVO FERIADO</h2>
            
            <form action="/dashboard/calendario/feriado" method="POST" class="filter-options">
                <label>NOME DO FERIADO</label>
                <input type="text" name="nome" class="filter-input" required>
                
                <label style="margin-top:15px">DATA</label>
                <input type="date" name="data" class="filter-input" required>
                
                <div style="margin-top:15px">
                    <label style="display:flex; align-items:center; gap:10px;">
                        <input type="checkbox" name="recorrente" value="true">
                        <span style="color:#fff">Feriado recorrente (todo ano)</span>
                    </label>
                </div>
                
                <button type="submit" class="btn-action" style="margin-top:25px; width:100%">
                    <i class="fas fa-save"></i> SALVAR FERIADO
                </button>
            </form>
        </div>
    </div>
    
    <script>
        let mesAtual = <%= filtros.mes %>;
        let anoAtual = <%= filtros.ano %>;
        
        function mudarMes(direcao) {
            mesAtual += direcao;
            if (mesAtual > 12) {
                mesAtual = 1;
                anoAtual++;
            } else if (mesAtual < 1) {
                mesAtual = 12;
                anoAtual--;
            }
            
            document.getElementById('mesInput').value = mesAtual;
            document.getElementById('anoInput').value = anoAtual;
            document.getElementById('filtroForm').submit();
        }
        
        function filtrarTurma(turma) {
            const form = document.getElementById('filtroForm');
            form.turma.value = turma;
            form.submit();
        }
        
        function abrirModalEvento() {
            document.getElementById('eventoModal').style.display = 'flex';
        }
        
        function abrirModalFeriado() {
            document.getElementById('feriadoModal').style.display = 'flex';
        }
        
        function fecharModal(modalId) {
            document.getElementById(modalId).style.display = 'none';
        }
        
        async function removerEvento(id) {
            if (!confirm('Remover este evento?')) return;
            
            try {
                const response = await fetch(`/dashboard/calendario/evento/${id}`, {
                    method: 'DELETE'
                });
                
                if (response.ok) {
                    location.reload();
                }
            } catch (err) {
                console.error(err);
            }
        }
        
        window.onclick = function(event) {
            if (event.target.classList.contains('modal-overlay')) {
                event.target.style.display = 'none';
            }
        }

        async function removerItem(tipo, id) {
            if (!confirm(`Remover este ${tipo}?`)) return;
            
            try {
                let url = '';
                if (tipo === 'feriado') {
                    url = `/dashboard/calendario/feriado/${id}`;
                } else {
                    url = `/dashboard/calendario/evento/${id}`;
                }
                
                const response = await fetch(url, { method: 'DELETE' });
                if (response.ok) location.reload();
            } catch (err) {
                console.error(err);
            }
        }
    </script>
</body>
</html>