<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AnalisAI - Login</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/CSS/login.css">
</head>
<body>

    <div>
        <a href="/" class="btn-secondary-dash back-button">
            <i class="fas fa-undo-alt"></i> VOLTAR
        </a>
    </div>

    <div class="page">
        <div class="logo-analisai">
            <img src="/IMG/logo3-white.png" alt="AnalisAI" id="logoimg">
        </div>

        <div class="login-container">
            
            <% if (error_msg && error_msg.length > 0) { %>
                <div class="erro-box">
                    <%= error_msg %>
                </div>
            <% } %>
            
            <% if (success_msg && success_msg.length > 0) { %>
                <div class="success-box">
                    <%= success_msg %>
                </div>
            <% } %>

            <div class="login-tabs">
                <div class="login-tab professor <%= tipo === 'professor' ? 'active' : '' %>" onclick="switchTab('professor')">
                    <i class="fas fa-chalkboard-teacher"></i> PROFESSOR
                </div>
                <div class="login-tab aluno <%= tipo === 'aluno' ? 'active' : '' %>" onclick="switchTab('aluno')">
                    <i class="fas fa-user-graduate"></i> ALUNO
                </div>
            </div>

            <div class="login-form professor <%= tipo === 'professor' ? 'active' : '' %>" id="professorForm">
                <form action="/login/professor" method="POST">
                    <div class="input-group">
                        <input type="text" name="usuario" placeholder="E-MAIL" required>
                    </div>
                    <div class="input-group">
                        <input type="password" name="senha" placeholder="SENHA" required>
                    </div>
                    <button type="submit" class="a">ENTRAR</button>
                </form>
                <a href="/esqueci-senha" class="link-esqueci">Esqueci minha senha</a>
            </div>

            <div class="login-form aluno <%= tipo === 'aluno' ? 'active' : '' %>" id="alunoForm">
                <form action="/login/aluno" method="POST">
                    <div class="info-box">
                        <i class="fas fa-info-circle"></i>
                        Use matrícula ou e-mail
                    </div>
                    <div class="input-group-2">
                        <input type="text" name="matricula" placeholder="MATRÍCULA">
                    </div>
                    <div class="input-group-2">
                        <input type="email" name="email" placeholder="E-MAIL">
                    </div>
                    <div class="input-group-2">
                        <input type="password" name="senha" placeholder="SENHA" required>
                    </div>
                    <button type="submit" class="b">ENTRAR COMO ALUNO</button>
                </form>
            </div>
            
        </div>

        <footer class="footer-terms">
            <a href="/termos" class="termos">TERMOS DE SERVIÇO</a>
        </footer>
    </div>

    <script>
        function switchTab(tipo) {
            const tabs = document.querySelectorAll('.login-tab');
            const forms = document.querySelectorAll('.login-form');
            const logo = document.getElementById('logoimg');
            
            tabs.forEach(tab => tab.classList.remove('active'));
            forms.forEach(form => form.classList.remove('active'));
            
            if (tipo === 'professor') {
                document.querySelector('.login-tab.professor').classList.add('active');
                document.getElementById('professorForm').classList.add('active');
                logo.src = '/IMG/logo3-white.png';
            } else {
                document.querySelector('.login-tab.aluno').classList.add('active');
                document.getElementById('alunoForm').classList.add('active');
                logo.src = '/IMG/logo3-green.png';
            }
        }
    </script>
</body>
</html>